# Database
DATABASE_URL="postgresql://user:password@localhost:5432/crm"
# Optional: required when your Postgres provider uses a custom CA certificate.
PG_SSL_ROOT_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional: explicit auth callback base. Useful in some deployments.
AUTH_URL="http://localhost:3000/api/auth"
# Optional compatibility/base URL used by some helpers in this app.
NEXTAUTH_URL="http://localhost:3000/api/auth"

# Public app URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CRM"

# S3-compatible storage (app/runtime)
NEXT_AWS_S3_ACCESS_KEY="your-s3-access-key"
NEXT_AWS_S3_ACCESS_SECRET="your-s3-secret-key"
NEXT_AWS_S3_BUCKET_NAME="your-bucket-name"
NEXT_AWS_S3_BUCKET_REGION="us-east-1"
NEXT_AWS_S3_ENDPOINT="https://s3.example-region.provider.com"

# S3 CORS bootstrap script (scripts/manage-s3-cors.ts)
# Comma-separated values where applicable.
S3_CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
S3_CORS_ALLOWED_METHODS="GET,HEAD,PUT"
S3_CORS_ALLOWED_HEADERS="*"
S3_CORS_EXPOSE_HEADERS="ETag"
S3_CORS_MAX_AGE_SECONDS="3000"
# Optional override for addressing style (true = path-style, false = virtual-hosted)
S3_FORCE_PATH_STYLE="true"

# Email Configuration (SMTP)
# Common SMTP providers:
# - Gmail: smtp.gmail.com (port 587, secure=false) - requires app-specific password
# - Outlook: smtp-mail.outlook.com (port 587, secure=false)
# - SendGrid: smtp.sendgrid.net (port 587, secure=false)
# - Mailgun: smtp.mailgun.org (port 587, secure=false)
# - Brevo: smtp-relay.brevo.com (port 587, secure=false)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"

# Optional first-admin bootstrap. No password is created; the user signs in
# through the configured SMTP magic link.
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_NAME="Local Admin"

# Observability / logging
SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
LOG_LEVEL="debug"
